<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
  <meta name="theme-color" content="#0f0f1a">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Lap Splitter">
  <link rel="manifest" href="./manifest.json">
  <link rel="apple-touch-icon" href="./icons/icon-192.png">
  <link rel="icon" type="image/png" href="./icons/icon-192.png">
  <title>Lap Splitter</title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Outfit', sans-serif;
      background: linear-gradient(145deg, #0f0f1a 0%, #1a1a2e 50%, #16213e 100%);
      color: #e8e8f0; min-height: 100vh; min-height: 100dvh;
      padding: 16px 20px 40px; padding-top: max(16px, env(safe-area-inset-top));
      max-width: 600px; margin: 0 auto; -webkit-font-smoothing: antialiased; overflow-x: hidden;
    }
    input:focus, button:focus { outline: none; }
    button { -webkit-tap-highlight-color: transparent; }

    .header { text-align: center; margin-bottom: 28px; padding-top: 8px; }
    .header-top { display: flex; align-items: center; justify-content: center; gap: 10px; margin-bottom: 4px; }
    .title { font-family: 'Outfit', sans-serif; font-size: 28px; font-weight: 800; letter-spacing: 0.15em; color: #fff; }
    .subtitle { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.25em; color: #888; }

    .section { margin-bottom: 24px; }
    .label { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.2em; color: #666; font-weight: 600; margin-bottom: 10px; }

    .race-row { display: flex; gap: 8px; }
    .race-btn { flex: 1; padding: 12px 8px; border: 1.5px solid #2a2a45; border-radius: 10px; background: transparent; cursor: pointer; display: flex; flex-direction: column; align-items: center; gap: 2px; transition: all 0.25s; }
    .race-btn.active { border-color: #FF6B4A; background: rgba(255,107,74,0.08); box-shadow: 0 0 20px rgba(255,107,74,0.1); }
    .race-btn-distance { font-family: 'JetBrains Mono', monospace; font-size: 20px; font-weight: 700; color: #fff; transition: color 0.25s; }
    .race-btn.active .race-btn-distance { color: #FF6B4A; }
    .race-btn-detail { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #666; }

    .goal-label-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
    .lock-btn { font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 600; padding: 5px 12px; border: 1.5px solid #444; border-radius: 8px; background: transparent; cursor: pointer; display: flex; align-items: center; gap: 6px; transition: all 0.25s; color: #666; }
    .lock-btn.locked { border-color: #FF6B4A; color: #FF6B4A; background: rgba(255,107,74,0.07); }
    .lock-hint { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #555; margin-bottom: 8px; font-style: italic; }

    .goal-row { display: flex; flex-direction: column; gap: 10px; }
    .goal-input-wrap { position: relative; display: inline-flex; align-items: center; }
    .goal-input { font-family: 'JetBrains Mono', monospace; font-size: 32px; font-weight: 700; color: #fff; background: #1e1e32; border: 2px solid #2a2a45; border-radius: 12px; padding: 10px 70px 10px 16px; width: 100%; max-width: 220px; }
    .goal-input:focus { border-color: #FF6B4A; }
    .goal-unit { position: absolute; right: 16px; font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #555; }
    .presets { display: flex; gap: 6px; flex-wrap: wrap; }
    .preset-btn { font-family: 'JetBrains Mono', monospace; font-size: 13px; padding: 6px 14px; border: 1.5px solid #2a2a45; border-radius: 8px; background: transparent; color: #999; cursor: pointer; transition: all 0.2s; }
    .preset-btn.active { border-color: #FF6B4A; color: #FF6B4A; background: rgba(255,107,74,0.08); }

    .strategy-row { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
    .strategy-btn { font-family: 'Outfit', sans-serif; font-size: 13px; padding: 8px 16px; border: 1.5px solid #2a2a45; border-radius: 8px; background: transparent; color: #999; cursor: pointer; display: flex; align-items: center; gap: 6px; transition: all 0.2s; }
    .strategy-btn.active { border-color: #4DC9F6; color: #4DC9F6; background: rgba(77,201,246,0.08); }
    .strategy-icon { font-size: 16px; }
    .custom-badge { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #9B6DFF; background: rgba(155,109,255,0.08); padding: 4px 10px; border-radius: 6px; font-weight: 600; display: none; }
    .custom-badge.show { display: block; }

    .bar-container { display: flex; height: 52px; border-radius: 8px; overflow: visible; position: relative; touch-action: none; }
    .bar-segment { display: flex; align-items: center; justify-content: center; position: relative; min-width: 20px; }
    .bar-label { font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 600; color: #000; text-shadow: 0 1px 2px rgba(255,255,255,0.2); pointer-events: none; white-space: nowrap; }
    .bar-divider { position: absolute; right: -10px; top: -8px; bottom: -8px; width: 20px; cursor: col-resize; z-index: 10; touch-action: none; }
    .bar-markers { display: flex; justify-content: space-between; margin-top: 6px; }
    .marker-text { font-family: 'JetBrains Mono', monospace; font-size: 9px; color: #444; }

    .lap-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .lap-card { background: #1a1a30; border-radius: 10px; padding: 14px 14px 12px; border-top: 3px solid; box-shadow: 0 2px 8px rgba(0,0,0,0.15); }
    .lap-header { display: flex; align-items: center; gap: 6px; margin-bottom: 6px; }
    .lap-dot { width: 8px; height: 8px; border-radius: 50%; }
    .lap-name { font-family: 'Outfit', sans-serif; font-size: 13px; font-weight: 600; color: #ccc; }
    .lap-dist { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #555; margin-left: auto; }
    .lap-time { font-family: 'JetBrains Mono', monospace; font-size: 26px; font-weight: 700; color: #fff; margin-bottom: 8px; }

    .lap-slider { width: 100%; height: 8px; border-radius: 4px; -webkit-appearance: none; appearance: none; cursor: pointer; margin-bottom: 8px; }
    .lap-slider::-webkit-slider-thumb { -webkit-appearance: none; width: 28px; height: 28px; border-radius: 50%; background: #fff; border: 2px solid #555; margin-top: -10px; box-shadow: 0 2px 8px rgba(0,0,0,0.5); }
    .lap-slider::-moz-range-thumb { width: 28px; height: 28px; border-radius: 50%; background: #fff; border: 2px solid #555; box-shadow: 0 2px 8px rgba(0,0,0,0.5); }
    .lap-slider::-webkit-slider-runnable-track { height: 8px; border-radius: 4px; }

    .lap-meta { display: flex; justify-content: space-between; }
    .lap-pace { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #777; }
    .lap-cum { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #555; }

    .tbl { background: #14142a; border-radius: 10px; overflow: hidden; border: 1px solid #222240; }
    .tbl-hdr { display: flex; padding: 10px 14px; border-bottom: 1px solid #222240; }
    .tc { flex: 1; font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #666; font-weight: 600; display: flex; align-items: center; gap: 6px; }
    .tc.n { flex: 0.8; }
    .trow { display: flex; padding: 10px 14px; border-bottom: 1px solid #1a1a35; }
    .tm { font-size: 13px; color: #ccc; font-weight: 500; }
    .tdot { width: 6px; height: 6px; border-radius: 50%; display: inline-block; }
    .tfoot { display: flex; padding: 12px 14px; background: #1a1a35; }
    .tb { font-weight: 700; }
  </style>
</head>
<body>

<div class="header">
  <div class="header-top">
    <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><ellipse cx="14" cy="14" rx="12" ry="10" stroke="#FF6B4A" stroke-width="2.5" stroke-dasharray="4 3"/><circle cx="14" cy="4" r="3" fill="#FF6B4A"/></svg>
    <span class="title">LAP SPLITTER</span>
  </div>
  <div class="subtitle" id="sub"></div>
</div>

<div class="section">
  <div class="label">RACE DISTANCE</div>
  <div class="race-row" id="raceRow"></div>
</div>

<div class="section">
  <div class="goal-label-row">
    <div class="label" style="margin-bottom:0">GOAL TIME</div>
    <button type="button" class="lock-btn" id="lockBtn"></button>
  </div>
  <div class="lock-hint" id="lockHint"></div>
  <div class="goal-row">
    <div class="goal-input-wrap">
      <input class="goal-input" id="goalInput" placeholder="m:ss.00" inputmode="decimal" autocomplete="off">
      <span class="goal-unit">m:ss</span>
    </div>
    <div class="presets" id="presetsRow"></div>
  </div>
</div>

<div class="section">
  <div class="label">SPLIT STRATEGY</div>
  <div class="strategy-row" id="stratRow"></div>
</div>

<div class="section">
  <div class="label">DRAG TO ADJUST SPLITS</div>
  <div class="bar-container" id="splitBar"></div>
  <div class="bar-markers" id="barMarkers"></div>
</div>

<div class="section">
  <div class="label">LAP TIMES</div>
  <div class="lap-grid" id="lapGrid"></div>
</div>

<div class="section">
  <div class="label">RACE SUMMARY</div>
  <div class="tbl">
    <div class="tbl-hdr">
      <span class="tc n">Lap</span><span class="tc">Split</span><span class="tc">Cumulative</span><span class="tc">Pace/mi</span>
    </div>
    <div id="tblBody"></div>
    <div class="tfoot" id="tblFoot"></div>
  </div>
</div>

<script>
var RACES = {
  400:  { dist:400,  lap:100, unit:'100m', goal:52,  presets:[{t:'0:48',v:48},{t:'0:52',v:52},{t:'0:56',v:56},{t:'1:00',v:60},{t:'1:05',v:65}], marks:['0m','100m','200m','300m','400m'] },
  800:  { dist:800,  lap:200, unit:'200m', goal:120, presets:[{t:'1:50',v:110},{t:'2:00',v:120},{t:'2:10',v:130},{t:'2:20',v:140},{t:'2:30',v:150}], marks:['0m','200m','400m','600m','800m'] },
  1600: { dist:1600, lap:400, unit:'400m', goal:300, presets:[{t:'4:00',v:240},{t:'4:30',v:270},{t:'5:00',v:300},{t:'5:30',v:330},{t:'6:00',v:360}], marks:['0m','400m','800m','1200m','1600m'] }
};
var COLORS = ['#FF6B4A','#FFB84D','#4DC9F6','#9B6DFF'];
var state = { race:1600, goal:300, laps:[75,75,75,75], strat:'even', locked:true };

function R() { return RACES[state.race]; }
function fmt(t) {
  if (!t || t < 0) return '0:00.00';
  var m = Math.floor(t/60), s = t%60, w = Math.floor(s), h = Math.round((s-w)*100);
  return m + ':' + String(w).padStart(2,'0') + '.' + String(h).padStart(2,'0');
}
function parse(str) {
  var c = str.replace(/[^0-9:.]/g,''), p = c.split(':');
  if (p.length === 2) return (parseInt(p[0])||0)*60 + (parseFloat(p[1])||0);
  return parseFloat(c) || 0;
}
function getTotal() { return state.laps[0]+state.laps[1]+state.laps[2]+state.laps[3]; }
function getCum() { var a=state.laps; return [a[0], a[0]+a[1], a[0]+a[1]+a[2], a[0]+a[1]+a[2]+a[3]]; }
function lapPace(t) { return fmt((t / R().lap) * 1609.34); }
function totalPace(t) { return fmt((t / R().dist) * 1609.34); }

/* Build the skeleton DOM - called once per race switch */
function buildUI() {
  var r = R();
  document.getElementById('sub').textContent = r.dist + 'M \u00B7 4 LAPS \u00B7 ' + r.unit + ' EACH';

  // Race buttons
  var html = '';
  [400,800,1600].forEach(function(d) {
    html += '<button type="button" class="race-btn' + (state.race===d?' active':'') + '" data-d="' + d + '">';
    html += '<span class="race-btn-distance">' + d + 'm</span>';
    html += '<span class="race-btn-detail">4\u00D7' + RACES[d].lap + 'm</span></button>';
  });
  document.getElementById('raceRow').innerHTML = html;
  document.querySelectorAll('.race-btn').forEach(function(btn) {
    btn.addEventListener('click', function() { switchRace(parseInt(this.dataset.d)); });
  });

  // Presets
  html = '';
  r.presets.forEach(function(p) {
    html += '<button type="button" class="preset-btn" data-v="' + p.v + '">' + p.t + '</button>';
  });
  document.getElementById('presetsRow').innerHTML = html;
  document.querySelectorAll('.preset-btn').forEach(function(btn) {
    btn.addEventListener('click', function() { setGoal(parseInt(this.dataset.v)); });
  });

  // Strategy buttons
  html = '';
  [{k:'even',n:'Even',i:'\u2550'},{k:'negative',n:'Negative',i:'\u2197'},{k:'positive',n:'Positive',i:'\u2198'}].forEach(function(s) {
    html += '<button type="button" class="strategy-btn" data-s="' + s.k + '">';
    html += '<span class="strategy-icon">' + s.i + '</span><span>' + s.n + '</span></button>';
  });
  html += '<div class="custom-badge" id="customBadge">Custom</div>';
  document.getElementById('stratRow').innerHTML = html;
  document.querySelectorAll('.strategy-btn').forEach(function(btn) {
    btn.addEventListener('click', function() { setStrategy(this.dataset.s); });
  });

  // Lock button - clone to remove old listeners
  var oldLock = document.getElementById('lockBtn');
  var newLock = oldLock.cloneNode(false);
  oldLock.parentNode.replaceChild(newLock, oldLock);
  newLock.id = 'lockBtn';
  newLock.type = 'button';
  newLock.addEventListener('click', function() { state.locked = !state.locked; updateUI(); });

  // Goal input - clone to remove old listeners
  var oldInput = document.getElementById('goalInput');
  var newInput = oldInput.cloneNode(false);
  oldInput.parentNode.replaceChild(newInput, oldInput);
  newInput.id = 'goalInput';
  newInput.value = fmt(state.goal);
  newInput.addEventListener('blur', function() {
    var v = parse(this.value);
    if (v >= 10 && v <= 1200) setGoal(v);
  });
  newInput.addEventListener('keydown', function(e) { if (e.key === 'Enter') this.blur(); });

  // Bar markers
  html = '';
  r.marks.forEach(function(m) { html += '<span class="marker-text">' + m + '</span>'; });
  document.getElementById('barMarkers').innerHTML = html;

  // Bar segments
  html = '';
  for (var i = 0; i < 4; i++) {
    var radius = i===0 ? 'border-radius:8px 0 0 8px;' : i===3 ? 'border-radius:0 8px 8px 0;' : '';
    html += '<div class="bar-segment" id="seg' + i + '" style="background:' + COLORS[i] + ';' + radius + '">';
    html += '<span class="bar-label" id="segLbl' + i + '"></span>';
    if (i < 3) html += '<div class="bar-divider" data-i="' + i + '"></div>';
    html += '</div>';
  }
  document.getElementById('splitBar').innerHTML = html;
  initBarDrag();

  // Lap cards
  html = '';
  for (var i = 0; i < 4; i++) {
    html += '<div class="lap-card" style="border-top-color:' + COLORS[i] + ';">';
    html += '<div class="lap-header"><div class="lap-dot" style="background:' + COLORS[i] + '"></div>';
    html += '<span class="lap-name">Lap ' + (i+1) + '</span>';
    html += '<span class="lap-dist" id="lapDist' + i + '">' + r.unit + '</span></div>';
    html += '<div class="lap-time" id="lapTime' + i + '"></div>';
    html += '<input type="range" class="lap-slider" id="lapSlider' + i + '" min="1" step="0.1">';
    html += '<div class="lap-meta"><span class="lap-pace" id="lapPace' + i + '"></span>';
    html += '<span class="lap-cum" id="lapCum' + i + '"></span></div></div>';
  }
  document.getElementById('lapGrid').innerHTML = html;

  // Attach slider listeners - these stay attached, never rebuilt during drag
  for (var i = 0; i < 4; i++) {
    (function(idx) {
      document.getElementById('lapSlider' + idx).addEventListener('input', function() {
        changeLap(idx, parseFloat(this.value));
      });
    })(i);
  }

  // Table rows
  html = '';
  for (var i = 0; i < 4; i++) {
    html += '<div class="trow">';
    html += '<span class="tc n"><span class="tdot" style="background:' + COLORS[i] + '"></span>' + (i+1) + '</span>';
    html += '<span class="tc tm" id="tSplit' + i + '"></span>';
    html += '<span class="tc tm" id="tCum' + i + '"></span>';
    html += '<span class="tc tm" id="tPace' + i + '"></span></div>';
  }
  document.getElementById('tblBody').innerHTML = html;
  document.getElementById('tblFoot').innerHTML =
    '<span class="tc n tb">Total</span>' +
    '<span class="tc tm tb" id="tTotal"></span>' +
    '<span class="tc"></span>' +
    '<span class="tc tm tb" id="tTotalPace"></span>';

  updateUI();
}

/* Update only text and values - never touches slider DOM during interaction */
function updateUI() {
  var r = R(), g = state.goal, L = state.laps, t = getTotal(), c = getCum();
  var barBase = state.locked ? g : t;

  // Lock button
  var lb = document.getElementById('lockBtn');
  lb.className = 'lock-btn' + (state.locked ? ' locked' : '');
  var lockPath = state.locked
    ? '<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>'
    : '<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/>';
  lb.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">' + lockPath + '</svg><span>' + (state.locked ? 'Locked' : 'Unlocked') + '</span>';

  document.getElementById('lockHint').textContent = state.locked
    ? 'Adjusting a lap redistributes time across other laps'
    : 'Adjusting a lap changes the total time freely';

  // Goal input - only if not focused
  var gi = document.getElementById('goalInput');
  if (document.activeElement !== gi) gi.value = fmt(g);

  // Preset highlights
  document.querySelectorAll('.preset-btn').forEach(function(b) {
    b.classList.toggle('active', parseInt(b.dataset.v) === g);
  });

  // Strategy highlights
  document.querySelectorAll('.strategy-btn').forEach(function(b) {
    b.classList.toggle('active', b.dataset.s === state.strat);
  });
  var cb = document.getElementById('customBadge');
  if (cb) cb.classList.toggle('show', state.strat === 'custom');

  // Bar segments + lap cards + table
  for (var i = 0; i < 4; i++) {
    // Bar
    document.getElementById('seg' + i).style.width = ((L[i] / barBase) * 100) + '%';
    document.getElementById('segLbl' + i).textContent = fmt(L[i]);

    // Lap card text
    document.getElementById('lapTime' + i).textContent = fmt(L[i]);
    document.getElementById('lapPace' + i).textContent = lapPace(L[i]) + '/mi';
    document.getElementById('lapCum' + i).textContent = '@ ' + fmt(c[i]);

    // Slider - update max and value only if not being touched
    var sl = document.getElementById('lapSlider' + i);
    var slMax = state.locked ? Math.max(g - 3, 4) : Math.max(g * 2, 60);
    sl.max = slMax;
    if (document.activeElement !== sl) {
      sl.value = L[i];
    }
    var fill = Math.min(100, Math.max(0, ((L[i] - 1) / (slMax - 1)) * 100));
    sl.style.background = 'linear-gradient(to right,' + COLORS[i] + ' 0%,' + COLORS[i] + ' ' + fill + '%,#2a2a3a ' + fill + '%,#2a2a3a 100%)';

    // Table
    document.getElementById('tSplit' + i).textContent = fmt(L[i]);
    document.getElementById('tCum' + i).textContent = fmt(c[i]);
    document.getElementById('tPace' + i).textContent = lapPace(L[i]);
  }

  document.getElementById('tTotal').textContent = fmt(t);
  document.getElementById('tTotalPace').textContent = totalPace(t);
}

function switchRace(key) {
  var rc = RACES[key];
  state.race = key;
  state.goal = rc.goal;
  var b = rc.goal / 4;
  state.laps = [b, b, b, b];
  state.strat = 'even';
  state.locked = true;
  buildUI();
}

function setGoal(secs) {
  state.goal = secs;
  var b = secs / 4;
  state.laps = [b, b, b, b];
  state.strat = 'even';
  updateUI();
}

function setStrategy(type) {
  state.strat = type;
  var avg = state.goal / 4;
  if (type === 'even') state.laps = [avg, avg, avg, avg];
  else if (type === 'negative') state.laps = [avg*1.08, avg*1.03, avg*0.97, avg*0.92];
  else if (type === 'positive') state.laps = [avg*0.92, avg*0.97, avg*1.03, avg*1.08];
  updateUI();
}

function changeLap(idx, val) {
  if (state.locked) {
    var clamped = Math.max(0.5, Math.min(state.goal - 1.5, val));
    var remaining = state.goal - clamped;
    var others = [0,1,2,3].filter(function(i) { return i !== idx; });
    var otherSum = others.reduce(function(s, i) { return s + state.laps[i]; }, 0);
    state.laps[idx] = clamped;
    if (otherSum > 0) {
      others.forEach(function(i) { state.laps[i] = (state.laps[i] / otherSum) * remaining; });
    } else {
      others.forEach(function(i) { state.laps[i] = remaining / 3; });
    }
  } else {
    state.laps[idx] = Math.max(0.5, Math.min(600, val));
    state.goal = getTotal();
  }
  state.strat = 'custom';
  updateUI();
}

function initBarDrag() {
  var bar = document.getElementById('splitBar');
  bar.querySelectorAll('.bar-divider').forEach(function(divider) {
    var idx = parseInt(divider.dataset.i);

    function onStart(e) {
      e.preventDefault();
      var rect = bar.getBoundingClientRect();
      var width = rect.width;

      function onMove(ev) {
        ev.preventDefault();
        var clientX = ev.touches ? ev.touches[0].clientX : ev.clientX;
        var dragTotal = state.locked ? state.goal : getTotal();
        var frac = Math.max(0.02, Math.min(0.98, (clientX - rect.left) / width));
        var prevSum = 0;
        for (var j = 0; j < idx; j++) prevSum += state.laps[j];
        var nextEnd = prevSum + state.laps[idx] + state.laps[idx + 1];
        var newVal = frac * dragTotal - prevSum;

        if (newVal >= 2 && nextEnd - prevSum - newVal >= 2) {
          state.laps[idx + 1] -= (newVal - state.laps[idx]);
          state.laps[idx] = newVal;
          state.strat = 'custom';
          updateUI();
        }
      }

      function onEnd() {
        document.removeEventListener('mousemove', onMove);
        document.removeEventListener('mouseup', onEnd);
        document.removeEventListener('touchmove', onMove);
        document.removeEventListener('touchend', onEnd);
      }

      document.addEventListener('mousemove', onMove);
      document.addEventListener('mouseup', onEnd);
      document.addEventListener('touchmove', onMove, { passive: false });
      document.addEventListener('touchend', onEnd);
    }

    divider.addEventListener('mousedown', onStart);
    divider.addEventListener('touchstart', onStart, { passive: false });
  });
}

// Start the app
buildUI();
</script>
</body>
</html>
