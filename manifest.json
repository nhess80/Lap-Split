<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
  <meta name="theme-color" content="#0f0f1a">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Lap Splitter">
  <link rel="manifest" href="./manifest.json">
  <link rel="apple-touch-icon" href="./icons/icon-192.png">
  <link rel="icon" type="image/png" href="./icons/icon-192.png">
  <title>Lap Splitter</title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Outfit', sans-serif;
      background: linear-gradient(145deg, #0f0f1a 0%, #1a1a2e 50%, #16213e 100%);
      color: #e8e8f0; min-height: 100vh; min-height: 100dvh;
      padding: 16px 20px 40px; padding-top: max(16px, env(safe-area-inset-top));
      max-width: 600px; margin: 0 auto; -webkit-font-smoothing: antialiased; overflow-x: hidden;
    }
    input:focus, button:focus { outline: none; }
    button { -webkit-tap-highlight-color: transparent; }
    .header { text-align: center; margin-bottom: 28px; padding-top: 8px; }
    .header-top { display: flex; align-items: center; justify-content: center; gap: 10px; margin-bottom: 4px; }
    .title { font-family: 'Outfit', sans-serif; font-size: 28px; font-weight: 800; letter-spacing: 0.15em; color: #fff; }
    .subtitle { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.25em; color: #888; }
    .section { margin-bottom: 24px; }
    .label { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.2em; color: #666; font-weight: 600; margin-bottom: 10px; }
    .race-row { display: flex; gap: 8px; }
    .race-btn { flex: 1; padding: 12px 8px; border: 1.5px solid #2a2a45; border-radius: 10px; background: transparent; cursor: pointer; display: flex; flex-direction: column; align-items: center; gap: 2px; transition: all 0.25s; }
    .race-btn.active { border-color: #FF6B4A; background: rgba(255,107,74,0.08); box-shadow: 0 0 20px rgba(255,107,74,0.1); }
    .race-btn-distance { font-family: 'JetBrains Mono', monospace; font-size: 20px; font-weight: 700; color: #fff; transition: color 0.25s; }
    .race-btn.active .race-btn-distance { color: #FF6B4A; }
    .race-btn-detail { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #666; }
    .goal-label-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
    .lock-btn { font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 600; padding: 5px 12px; border: 1.5px solid #444; border-radius: 8px; background: transparent; cursor: pointer; display: flex; align-items: center; gap: 6px; transition: all 0.25s; color: #666; }
    .lock-btn.locked { border-color: #FF6B4A; color: #FF6B4A; background: rgba(255,107,74,0.07); }
    .lock-hint { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #555; margin-bottom: 8px; font-style: italic; }
    .goal-row { display: flex; flex-direction: column; gap: 10px; }
    .goal-input-wrap { position: relative; display: inline-flex; align-items: center; }
    .goal-input { font-family: 'JetBrains Mono', monospace; font-size: 32px; font-weight: 700; color: #fff; background: #1e1e32; border: 2px solid #2a2a45; border-radius: 12px; padding: 10px 70px 10px 16px; width: 100%; max-width: 220px; }
    .goal-input:focus { border-color: #FF6B4A; }
    .goal-unit { position: absolute; right: 16px; font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #555; }
    .presets { display: flex; gap: 6px; flex-wrap: wrap; }
    .preset-btn { font-family: 'JetBrains Mono', monospace; font-size: 13px; padding: 6px 14px; border: 1.5px solid #2a2a45; border-radius: 8px; background: transparent; color: #999; cursor: pointer; transition: all 0.2s; }
    .preset-btn.active { border-color: #FF6B4A; color: #FF6B4A; background: rgba(255,107,74,0.08); }
    .strategy-row { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
    .strategy-btn { font-family: 'Outfit', sans-serif; font-size: 13px; padding: 8px 16px; border: 1.5px solid #2a2a45; border-radius: 8px; background: transparent; color: #999; cursor: pointer; display: flex; align-items: center; gap: 6px; transition: all 0.2s; }
    .strategy-btn.active { border-color: #4DC9F6; color: #4DC9F6; background: rgba(77,201,246,0.08); }
    .strategy-icon { font-size: 16px; }
    .custom-badge { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #9B6DFF; background: rgba(155,109,255,0.08); padding: 4px 10px; border-radius: 6px; font-weight: 600; display: none; }
    .custom-badge.show { display: block; }
    .bar-container { display: flex; height: 52px; border-radius: 8px; overflow: visible; position: relative; touch-action: none; }
    .bar-segment { display: flex; align-items: center; justify-content: center; position: relative; min-width: 20px; }
    .bar-label { font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 600; color: #000; text-shadow: 0 1px 2px rgba(255,255,255,0.2); pointer-events: none; white-space: nowrap; }
    .bar-divider { position: absolute; right: -10px; top: -8px; bottom: -8px; width: 20px; cursor: col-resize; z-index: 10; touch-action: none; }
    .bar-markers { display: flex; justify-content: space-between; margin-top: 6px; }
    .marker-text { font-family: 'JetBrains Mono', monospace; font-size: 9px; color: #444; }
    .lap-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .lap-card { background: #1a1a30; border-radius: 10px; padding: 14px 14px 12px; border-top: 3px solid; box-shadow: 0 2px 8px rgba(0,0,0,0.15); }
    .lap-header { display: flex; align-items: center; gap: 6px; margin-bottom: 6px; }
    .lap-dot { width: 8px; height: 8px; border-radius: 50%; }
    .lap-name { font-family: 'Outfit', sans-serif; font-size: 13px; font-weight: 600; color: #ccc; }
    .lap-dist { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #555; margin-left: auto; }
    .lap-time { font-family: 'JetBrains Mono', monospace; font-size: 26px; font-weight: 700; color: #fff; margin-bottom: 8px; }
    .lap-slider { width: 100%; height: 8px; border-radius: 4px; -webkit-appearance: none; appearance: none; cursor: pointer; margin-bottom: 8px; }
    .lap-slider::-webkit-slider-thumb { -webkit-appearance: none; width: 28px; height: 28px; border-radius: 50%; background: #fff; border: 2px solid #555; margin-top: -10px; box-shadow: 0 2px 8px rgba(0,0,0,0.5); }
    .lap-slider::-moz-range-thumb { width: 28px; height: 28px; border-radius: 50%; background: #fff; border: 2px solid #555; box-shadow: 0 2px 8px rgba(0,0,0,0.5); }
    .lap-slider::-webkit-slider-runnable-track { height: 8px; border-radius: 4px; }
    .lap-meta { display: flex; justify-content: space-between; }
    .lap-pace { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #777; }
    .lap-cum { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #555; }
    .table { background: #14142a; border-radius: 10px; overflow: hidden; border: 1px solid #222240; }
    .table-header { display: flex; padding: 10px 14px; border-bottom: 1px solid #222240; }
    .tc { flex: 1; font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #666; font-weight: 600; display: flex; align-items: center; gap: 6px; }
    .tc.n { flex: 0.8; }
    .tr { display: flex; padding: 10px 14px; border-bottom: 1px solid #1a1a35; }
    .tm { font-size: 13px; color: #ccc; font-weight: 500; }
    .td { width: 6px; height: 6px; border-radius: 50%; display: inline-block; }
    .tf { display: flex; padding: 12px 14px; background: #1a1a35; }
    .tb { font-weight: 700; }
  </style>
</head>
<body>
<div class="header">
  <div class="header-top">
    <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><ellipse cx="14" cy="14" rx="12" ry="10" stroke="#FF6B4A" stroke-width="2.5" stroke-dasharray="4 3"/><circle cx="14" cy="4" r="3" fill="#FF6B4A"/></svg>
    <span class="title">LAP SPLITTER</span>
  </div>
  <div class="subtitle" id="sub"></div>
</div>
<div class="section"><div class="label">RACE DISTANCE</div><div class="race-row" id="rr"></div></div>
<div class="section">
  <div class="goal-label-row"><div class="label" style="margin-bottom:0">GOAL TIME</div><button type="button" class="lock-btn" id="lb"></button></div>
  <div class="lock-hint" id="lh"></div>
  <div class="goal-row"><div class="goal-input-wrap"><input class="goal-input" id="gi" placeholder="m:ss.00" inputmode="decimal" autocomplete="off"><span class="goal-unit">m:ss</span></div><div class="presets" id="pr"></div></div>
</div>
<div class="section"><div class="label">SPLIT STRATEGY</div><div class="strategy-row" id="sr"></div></div>
<div class="section"><div class="label">DRAG TO ADJUST SPLITS</div><div class="bar-container" id="bar"></div><div class="bar-markers" id="bm"></div></div>
<div class="section"><div class="label">LAP TIMES</div><div class="lap-grid" id="lg"></div></div>
<div class="section"><div class="label">RACE SUMMARY</div>
  <div class="table"><div class="table-header"><span class="tc n">Lap</span><span class="tc">Split</span><span class="tc">Cumulative</span><span class="tc">Pace/mi</span></div><div id="tb"></div><div class="tf" id="tt"></div></div>
</div>

<script>
// Kill any leftover service workers from previous version
if('serviceWorker'in navigator){navigator.serviceWorker.getRegistrations().then(function(r){r.forEach(function(reg){reg.unregister()})});}
if('caches'in window){caches.keys().then(function(k){k.forEach(function(n){caches.delete(n)})});}

var RC={400:{d:400,ld:100,u:'100m',dg:52,p:[{l:'0:48',s:48},{l:'0:52',s:52},{l:'0:56',s:56},{l:'1:00',s:60},{l:'1:05',s:65}],m:['0m','100m','200m','300m','400m']},800:{d:800,ld:200,u:'200m',dg:120,p:[{l:'1:50',s:110},{l:'2:00',s:120},{l:'2:10',s:130},{l:'2:20',s:140},{l:'2:30',s:150}],m:['0m','200m','400m','600m','800m']},1600:{d:1600,ld:400,u:'400m',dg:300,p:[{l:'4:00',s:240},{l:'4:30',s:270},{l:'5:00',s:300},{l:'5:30',s:330},{l:'6:00',s:360}],m:['0m','400m','800m','1200m','1600m']}};
var CO=['#FF6B4A','#FFB84D','#4DC9F6','#9B6DFF'];
var S={rk:1600,g:300,l:[75,75,75,75],st:'even',lk:true};
function r(){return RC[S.rk];}
function fmt(t){if(!t||t<0)return'0:00.00';var m=Math.floor(t/60),s=t%60,w=Math.floor(s),h=Math.round((s-w)*100);return m+':'+String(w).padStart(2,'0')+'.'+String(h).padStart(2,'0');}
function pt(str){var c=str.replace(/[^0-9:.]/g,''),p=c.split(':');if(p.length===2)return(parseInt(p[0])||0)*60+(parseFloat(p[1])||0);return parseFloat(c)||0;}
function tot(){return S.l[0]+S.l[1]+S.l[2]+S.l[3];}
function cum(){return[S.l[0],S.l[0]+S.l[1],S.l[0]+S.l[1]+S.l[2],S.l[0]+S.l[1]+S.l[2]+S.l[3]];}
function lp(t){return fmt((t/r().ld)*1609.34);}
function tp(t){return fmt((t/r().d)*1609.34);}

function build(){
  var rc=r();
  document.getElementById('sub').textContent=rc.d+'M \u00B7 4 LAPS \u00B7 '+rc.u+' EACH';
  var h='';[400,800,1600].forEach(function(d){h+='<button type="button" class="race-btn'+(S.rk===d?' active':'')+'" data-r="'+d+'"><span class="race-btn-distance">'+d+'m</span><span class="race-btn-detail">4\u00D7'+RC[d].ld+'m</span></button>';});
  document.getElementById('rr').innerHTML=h;
  document.querySelectorAll('.race-btn').forEach(function(b){b.addEventListener('click',function(){sw(parseInt(this.dataset.r));});});

  h='';rc.p.forEach(function(p){h+='<button type="button" class="preset-btn" data-s="'+p.s+'">'+p.l+'</button>';});
  document.getElementById('pr').innerHTML=h;
  document.querySelectorAll('.preset-btn').forEach(function(b){b.addEventListener('click',function(){ag(parseInt(this.dataset.s));});});

  h='';[{k:'even',l:'Even',i:'\u2550'},{k:'negative',l:'Negative',i:'\u2197'},{k:'positive',l:'Positive',i:'\u2198'}].forEach(function(s){h+='<button type="button" class="strategy-btn" data-st="'+s.k+'"><span class="strategy-icon">'+s.i+'</span><span>'+s.l+'</span></button>';});
  h+='<div class="custom-badge" id="cb">Custom</div>';
  document.getElementById('sr').innerHTML=h;
  document.querySelectorAll('.strategy-btn').forEach(function(b){b.addEventListener('click',function(){as(this.dataset.st);});});

  var ol=document.getElementById('lb'),nl=ol.cloneNode(false);ol.parentNode.replaceChild(nl,ol);nl.id='lb';nl.type='button';
  nl.addEventListener('click',function(){S.lk=!S.lk;upd();});

  var og=document.getElementById('gi'),ng=og.cloneNode(false);og.parentNode.replaceChild(ng,og);ng.id='gi';ng.value=fmt(S.g);
  ng.addEventListener('blur',function(){var s=pt(this.value);if(s>=10&&s<=1200)ag(s);});
  ng.addEventListener('keydown',function(e){if(e.key==='Enter')this.blur();});

  h='';rc.m.forEach(function(m){h+='<span class="marker-text">'+m+'</span>';});
  document.getElementById('bm').innerHTML=h;

  h='';for(var i=0;i<4;i++){var br=i===0?'border-radius:8px 0 0 8px;':i===3?'border-radius:0 8px 8px 0;':'';h+='<div class="bar-segment" id="bs'+i+'" style="background:'+CO[i]+';'+br+'"><span class="bar-label" id="bl'+i+'"></span>'+(i<3?'<div class="bar-divider" data-i="'+i+'"></div>':'')+'</div>';}
  document.getElementById('bar').innerHTML=h;
  setupDrag();

  h='';for(var i=0;i<4;i++){h+='<div class="lap-card" style="border-top-color:'+CO[i]+';"><div class="lap-header"><div class="lap-dot" style="background:'+CO[i]+'"></div><span class="lap-name">Lap '+(i+1)+'</span><span class="lap-dist" id="ld'+i+'">'+rc.u+'</span></div><div class="lap-time" id="lt'+i+'"></div><input type="range" class="lap-slider" id="ls'+i+'" min="1" step="0.1" value="'+S.l[i]+'"><div class="lap-meta"><span class="lap-pace" id="lp'+i+'"></span><span class="lap-cum" id="lc'+i+'"></span></div></div>';}
  document.getElementById('lg').innerHTML=h;
  for(var i=0;i<4;i++){(function(x){document.getElementById('ls'+x).addEventListener('input',function(){hlc(x,parseFloat(this.value));});})(i);}

  h='';for(var i=0;i<4;i++){h+='<div class="tr"><span class="tc n"><span class="td" style="background:'+CO[i]+'"></span>'+(i+1)+'</span><span class="tc tm" id="ts'+i+'"></span><span class="tc tm" id="tc'+i+'"></span><span class="tc tm" id="tp'+i+'"></span></div>';}
  document.getElementById('tb').innerHTML=h;
  document.getElementById('tt').innerHTML='<span class="tc n tb">Total</span><span class="tc tm tb" id="tts"></span><span class="tc"></span><span class="tc tm tb" id="ttp"></span>';
  upd();
}

function upd(){
  var rc=r(),g=S.g,l=S.l,t=tot(),c=cum(),bt=S.lk?g:t;
  var lb=document.getElementById('lb');lb.className='lock-btn'+(S.lk?' locked':'');
  var lsvg=S.lk?'<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>':'<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/>';
  lb.innerHTML='<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">'+lsvg+'</svg><span>'+(S.lk?'Locked':'Unlocked')+'</span>';
  document.getElementById('lh').textContent=S.lk?'Adjusting a lap redistributes time across other laps':'Adjusting a lap changes the total time freely';
  var gi=document.getElementById('gi');if(document.activeElement!==gi)gi.value=fmt(g);
  document.querySelectorAll('.preset-btn').forEach(function(b){b.classList.toggle('active',parseInt(b.dataset.s)===g);});
  document.querySelectorAll('.strategy-btn').forEach(function(b){b.classList.toggle('active',b.dataset.st===S.st);});
  var cb=document.getElementById('cb');if(cb)cb.classList.toggle('show',S.st==='custom');
  for(var i=0;i<4;i++){
    document.getElementById('bs'+i).style.width=((l[i]/bt)*100)+'%';
    document.getElementById('bl'+i).textContent=fmt(l[i]);
    document.getElementById('lt'+i).textContent=fmt(l[i]);
    document.getElementById('lp'+i).textContent=lp(l[i])+'/mi';
    document.getElementById('lc'+i).textContent='@ '+fmt(c[i]);
    var sl=document.getElementById('ls'+i),mx=S.lk?Math.max(g-3,4):Math.max(g*2,60);
    sl.max=mx;if(document.activeElement!==sl)sl.value=l[i];
    var pf=Math.min(100,Math.max(0,((l[i]-1)/(mx-1))*100));
    sl.style.background='linear-gradient(to right,'+CO[i]+' 0%,'+CO[i]+' '+pf+'%,#2a2a3a '+pf+'%,#2a2a3a 100%)';
    document.getElementById('ts'+i).textContent=fmt(l[i]);
    document.getElementById('tc'+i).textContent=fmt(c[i]);
    document.getElementById('tp'+i).textContent=lp(l[i]);
  }
  document.getElementById('tts').textContent=fmt(t);
  document.getElementById('ttp').textContent=tp(t);
}

function sw(k){var rc=RC[k];S.rk=k;S.g=rc.dg;var b=rc.dg/4;S.l=[b,b,b,b];S.st='even';S.lk=true;build();}
function ag(s){S.g=s;var b=s/4;S.l=[b,b,b,b];S.st='even';upd();}
function as(t){S.st=t;var a=S.g/4;if(t==='even')S.l=[a,a,a,a];else if(t==='negative')S.l=[a*1.08,a*1.03,a*0.97,a*0.92];else if(t==='positive')S.l=[a*0.92,a*0.97,a*1.03,a*1.08];upd();}
function hlc(x,v){
  if(S.lk){var cl=Math.max(0.5,Math.min(S.g-1.5,v)),rm=S.g-cl,ot=[0,1,2,3].filter(function(i){return i!==x;}),os=ot.reduce(function(s,i){return s+S.l[i];},0);S.l[x]=cl;if(os>0)ot.forEach(function(i){S.l[i]=(S.l[i]/os)*rm;});else ot.forEach(function(i){S.l[i]=rm/3;});}
  else{S.l[x]=Math.max(0.5,Math.min(600,v));S.g=tot();}
  S.st='custom';upd();
}
function setupDrag(){
  var bar=document.getElementById('bar');
  bar.querySelectorAll('.bar-divider').forEach(function(div){
    var idx=parseInt(div.dataset.i);
    function onS(e){e.preventDefault();var rect=bar.getBoundingClientRect(),w=rect.width;
      function onM(ev){ev.preventDefault();var cx=ev.touches?ev.touches[0].clientX:ev.clientX,dt=S.lk?S.g:tot(),fr=Math.max(0.02,Math.min(0.98,(cx-rect.left)/w)),pv=0;for(var j=0;j<idx;j++)pv+=S.l[j];var ne=pv+S.l[idx]+S.l[idx+1],nv=fr*dt-pv;if(nv>=2&&ne-pv-nv>=2){S.l[idx+1]-=(nv-S.l[idx]);S.l[idx]=nv;S.st='custom';upd();}}
      function onE(){document.removeEventListener('mousemove',onM);document.removeEventListener('mouseup',onE);document.removeEventListener('touchmove',onM);document.removeEventListener('touchend',onE);}
      document.addEventListener('mousemove',onM);document.addEventListener('mouseup',onE);document.addEventListener('touchmove',onM,{passive:false});document.addEventListener('touchend',onE);}
    div.addEventListener('mousedown',onS);div.addEventListener('touchstart',onS,{passive:false});
  });
}
build();
</script>
</body>
</html>
